{{ 'megaska-bag.css' | asset_url | stylesheet_tag }}
<script src="{{ 'megaska-bag.js' | asset_url }}" defer="defer"></script>

<div id="megaska-bag-page" class="megaska-bag-page">
  <div class="megaska-bag-shell">
    <header class="megaska-bag-header">
      <div class="megaska-bag-header__inner">
        <p class="megaska-bag-header__eyebrow">Megaska</p>
        <h1 class="megaska-bag-header__title">Your Bag</h1>
        <p class="megaska-bag-header__subtitle">Your beach bag is almost ready.</p>
      </div>
    </header>

    <div id="megaska-bag-root" class="megaska-bag-root" data-page="bag">
      <div id="megaska-bag-loading" class="megaska-bag-loading">
        Loading your bag...
      </div>
    </div>

    <noscript>
      <div class="megaska-bag-noscript">
        Please enable JavaScript to use the Megaska Bag experience.
      </div>
    </noscript>
  </div>
</div>

{% schema %}
{
  "name": "Megaska Bag Page",
  "settings": []
}
{% endschema %}
