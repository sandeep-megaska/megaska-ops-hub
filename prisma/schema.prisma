generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  }

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model MegaskaCustomerProfile {
  id                String                       @id @default(cuid())
  phoneE164         String                       @unique
  email             String?
  firstName         String?
  lastName          String?
  shopifyCustomerId String?                      @unique
  marketingOptIn    Boolean                      @default(false)
  authSessions      MegaskaCustomerAuthSession[]
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@index([email])
}

model MegaskaCustomerAuthSession {
  id                String                  @id @default(cuid())
  sessionTokenHash  String                  @unique
  phoneE164         String
  customerProfileId String?
  customerProfile   MegaskaCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  expiresAt         DateTime
  revokedAt         DateTime?
  lastSeenAt        DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([phoneE164])
  @@index([customerProfileId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model OpsRequest {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)
  shop_domain    String
  request_no     String?
  request_type   String
  status         String   @default("NEW")
  order_id       String?
  order_name     String?
  customer_name  String?
  customer_email String?
  customer_phone String?
  reason         String?
  payload        Json     @default("{}")

  @@map("ops_requests")
  @@index([shop_domain, created_at], map: "ops_requests_shop_created_idx")
  @@index([status], map: "ops_requests_status_idx")
  @@index([request_type], map: "ops_requests_type_idx")
}