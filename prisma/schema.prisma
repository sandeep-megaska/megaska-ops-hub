generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CustomerProfile {
  id                  String   @id @default(uuid())
  phoneE164           String   @unique
  fullName            String?
  firstName           String?
  lastName            String?
  email               String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  stateProvince       String?
  postalCode          String?
  countryRegion       String?
  shopifyCustomerId   String?
  phoneVerifiedAt     DateTime?
  profileCompletedAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sessions            AuthSession[]
  otpChallenges       OTPChallenge[]
  orderActionRequests OrderActionRequest[]
  walletAccounts      WalletAccount[]
  walletTransactions  WalletTransaction[]
  walletReservations  WalletReservation[]
  gstDocuments       GstDocument[]
  gstParties         GstParty[]

}

model AuthSession {
  id                  String   @id @default(uuid())
  customerProfileId   String
  sessionTokenHash    String   @unique
  expiresAt           DateTime
  revokedAt           DateTime?
  lastSeenAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customer            CustomerProfile @relation(fields: [customerProfileId], references: [id])
}

  model OTPChallenge {
    id              String   @id @default(uuid())
    phoneE164       String
  provider        String   // twilio, msg91, mock
    providerSid     String?
    status          String   // pending, verified, failed, expired
    attemptsCount   Int      @default(0)
    requestedAt     DateTime @default(now())
    verifiedAt      DateTime?
    expiresAt       DateTime
    metadata        Json?
    createdAt       DateTime @default(now())

    customerProfileId String?
    customer          CustomerProfile? @relation(fields: [customerProfileId], references: [id])
  }

model AuditEvent {
  id            String   @id @default(uuid())
  actorType     String   // customer, system, admin
  actorId       String?
  eventType     String
  entityType    String
  entityId      String?
  payload       Json?
  createdAt     DateTime @default(now())
}

enum RequestType {
  EXCHANGE
  REFUND
  CANCELLATION
  ISSUE
}

enum ExchangeRequestStatus {
  OPEN
  AWAITING_PAYMENT
  PAYMENT_RECEIVED
  PICKUP_PENDING
  PICKUP_SCHEDULED
  PICKUP_COMPLETED
  ITEM_RECEIVED
  APPROVED
  REJECTED
  REPLACEMENT_PROCESSING
  REPLACEMENT_SHIPPED
  CLOSED
}

enum PaymentPurpose {
  REVERSE_PICKUP_FEE
}

enum PaymentProvider {
  RAZORPAY
}

enum PaymentStatus {
  NOT_CREATED
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum ShipmentDirection {
  REVERSE_PICKUP
  FORWARD_REPLACEMENT
}

enum ShipmentStatus {
  NOT_STARTED
  PENDING
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  FAILED
}

model OrderActionRequest {
  id                    String                @id @default(uuid())
  requestType           RequestType           @default(EXCHANGE)
  customerProfileId     String
  shopifyCustomerId     String?
  shopifyOrderId        String?
  orderNumber           String
  status                ExchangeRequestStatus @default(OPEN)
  reason                String?
  customerNote          String?
  adminNote             String?
  requestedAt           DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  customerNameSnapshot  String?
  customerPhoneSnapshot String?
  customerEmailSnapshot String?
  orderAmountSnapshot   String?
  deliveryDateSnapshot  DateTime?
  eligibilityDecision   String?
  eligibilityReason     String?

  customerProfile       CustomerProfile       @relation(fields: [customerProfileId], references: [id])
  items                 OrderActionItem[]
  payments              RequestPayment[]
  shipments             ShipmentTracking[]

  @@index([customerProfileId])
  @@index([status])
  @@index([orderNumber])
}

model OrderActionItem {
  id                 String             @id @default(uuid())
  requestId          String
  shopifyLineItemId  String?
  productTitle       String
  variantTitle       String?
  sku                String?
  currentSize        String?
  requestedSize      String
  quantity           Int                @default(1)
  isClearance        Boolean            @default(false)
  isExcludedCategory Boolean            @default(false)
  eligibilitySnapshot Json?
  createdAt          DateTime           @default(now())

  request            OrderActionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model RequestPayment {
  id                  String         @id @default(uuid())
  requestId           String
  purpose             PaymentPurpose @default(REVERSE_PICKUP_FEE)
  provider            PaymentProvider @default(RAZORPAY)
  amount              Int
  currency            String         @default("INR")
  status              PaymentStatus  @default(NOT_CREATED)
  paymentLinkId       String?
  paymentLinkUrl      String?
  providerReferenceId String?
  paymentId           String?
  paidAt              DateTime?
  expiresAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  request             OrderActionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([status])
  @@index([paymentLinkId])
}

model ShipmentTracking {
  id          String            @id @default(uuid())
  requestId   String
  direction   ShipmentDirection
  carrier     String?
  awb         String?
  trackingUrl String?
  status      ShipmentStatus    @default(NOT_STARTED)
  pickupAt    DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  remarks     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  request     OrderActionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@unique([requestId, direction])
}

enum WalletDirection {
  CREDIT
  DEBIT
}

enum WalletTransactionType {
  COD_REFUND_CREDIT
  MANUAL_CREDIT
  MANUAL_DEBIT
  ADJUSTMENT
  GOODWILL_CREDIT
  CHECKOUT_REDEMPTION
}

enum WalletSourceType {
  ISSUE_REQUEST
  ADMIN_MANUAL
  WALLET_RESERVATION
}

enum WalletActorType {
  SYSTEM
  ADMIN
}

model WalletAccount {
  id                String   @id @default(uuid())
  customerProfileId String
  currency          String   @default("INR")
  currentBalance    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer          CustomerProfile     @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  transactions      WalletTransaction[]
  reservations      WalletReservation[]

  @@unique([customerProfileId, currency])
  @@index([customerProfileId])
}

model WalletTransaction {
  id                  String                @id @default(uuid())
  walletAccountId     String
  customerProfileId   String
  direction           WalletDirection
  transactionType     WalletTransactionType
  amount              Int
  currency            String                @default("INR")
  sourceType          WalletSourceType
  sourceId            String?
  sourceReference     String?
  orderNumber         String?
  reason              String?
  adminNote           String?
  createdByType       WalletActorType
  createdById         String?
  createdAt           DateTime              @default(now())

  walletAccount       WalletAccount         @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  customer            CustomerProfile       @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([customerProfileId, createdAt])
  @@index([walletAccountId, createdAt])
  @@index([sourceType, sourceId])
  @@unique([sourceType, sourceId, transactionType])
}


enum WalletReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
  EXPIRED
}

enum WalletReservationSourceFlow {
  CHECKOUT
  BUY_NOW
}

model WalletReservation {
  id                String                      @id @default(uuid())
  walletAccountId   String
  customerProfileId String
  reservedAmount    Int
  currency          String                      @default("INR")
  status            WalletReservationStatus     @default(ACTIVE)
  discountCode      String?
  shopifyDiscountId String?
  sourceFlow        WalletReservationSourceFlow @default(CHECKOUT)
  cartReference     String?
  checkoutReference String?
  sessionReference  String?
  orderNumber       String?
  shopifyOrderId    String?
  releaseReason     String?
  expiresAt         DateTime
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  walletAccount     WalletAccount               @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  customer          CustomerProfile             @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([customerProfileId, status, expiresAt])
  @@index([walletAccountId, status, expiresAt])
  @@index([discountCode])
  @@index([shopifyOrderId])
}


enum GstDocumentType {
  TAX_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum GstDocumentStatus {
  DRAFT
  ISSUED
  CANCELLED
  VOID
  FAILED
}

enum GstNumberingStrategy {
  FINANCIAL_YEAR_SEQUENCE
  CALENDAR_YEAR_SEQUENCE
  MONTHLY_SEQUENCE
  MANUAL
}

enum GstSupplyType {
  B2B
  B2C
  EXPORT
  SEZ_WITH_PAYMENT
  SEZ_WITHOUT_PAYMENT
  DEEMED_EXPORT
}

model GstSettings {
  id                    String   @id @default(uuid())
  legalName             String
  tradeName             String?
  gstin                 String   @unique
  pan                   String?
  stateCode             String
  invoicePrefix         String
  creditNotePrefix      String
  debitNotePrefix       String
  invoiceNumberStrategy GstNumberingStrategy
  defaultCurrency       String   @default("INR")
  einvoiceEnabled       Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  documents             GstDocument[]
  counters              GstCounter[]
  exports               GstExport[]
  reconciliationRuns    GstReconciliationRun[]
  auditLogs             GstAuditLog[]

}

model GstCounter {
  id            String      @id @default(uuid())
  gstSettingsId String
  documentType  GstDocumentType
  financialYear String
  lastNumber    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  gstSettings   GstSettings @relation(fields: [gstSettingsId], references: [id], onDelete: Cascade)

  @@unique([gstSettingsId, documentType, financialYear])
  @@index([gstSettingsId, documentType])
}

model GstDocument {
  id                     String            @id @default(uuid())
  documentType           GstDocumentType
  status                 GstDocumentStatus
  documentNumber         String            @unique
  documentDate           DateTime
  gstSettingsId          String
  gstSettings            GstSettings       @relation(fields: [gstSettingsId], references: [id])

  shopifyOrderId         String?
  shopifyOrderName       String?
  sourceOrderId          String?
  sourceOrderNumber      String?
  sourceReference        String?
  customerProfileId      String?
  customer               CustomerProfile?  @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  originalDocumentId     String?
  originalDocument       GstDocument?      @relation("GstDocToOriginal", fields: [originalDocumentId], references: [id])
  derivedNotes           GstDocument[]     @relation("GstDocToOriginal")

  supplyType             GstSupplyType
  placeOfSupplyStateCode String
  isInterstate           Boolean
  currency               String            @default("INR")

  taxableAmount          Decimal           @db.Decimal(14, 2)
  cgstAmount             Decimal           @db.Decimal(14, 2)
  sgstAmount             Decimal           @db.Decimal(14, 2)
  igstAmount             Decimal           @db.Decimal(14, 2)
  cessAmount             Decimal           @db.Decimal(14, 2)
  totalAmount            Decimal           @db.Decimal(14, 2)

  pdfFileUrl             String?
  jsonSnapshot           Json
  metadata               Json?
  issuedAt               DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  lines                  GstDocumentLine[]
  exportItems            GstExportItem[]
  auditLogs              GstAuditLog[]
  legacyLinks            GstLegacyDocument[]

  @@index([gstSettingsId])
  @@index([customerProfileId])
  @@index([sourceOrderId])
  @@index([sourceOrderNumber])
  @@index([originalDocumentId])
  @@index([status, documentDate])
}

model GstDocumentLine {
  id            String      @id @default(uuid())
  gstDocumentId String
  lineNumber    Int
  description   String
  hsnOrSac      String?
  quantity      Decimal     @db.Decimal(14, 3)
  unit          String?
  unitPrice     Decimal     @db.Decimal(14, 2)
  discount      Decimal     @db.Decimal(14, 2) @default(0)
  taxableAmount Decimal     @db.Decimal(14, 2)
  taxRate       Decimal     @db.Decimal(5, 2)
  cgstAmount    Decimal     @db.Decimal(14, 2)
  sgstAmount    Decimal     @db.Decimal(14, 2)
  igstAmount    Decimal     @db.Decimal(14, 2)
  cessAmount    Decimal     @db.Decimal(14, 2)
  lineTotal     Decimal     @db.Decimal(14, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  document      GstDocument @relation(fields: [gstDocumentId], references: [id], onDelete: Cascade)

  @@unique([gstDocumentId, lineNumber])
  @@index([gstDocumentId])
}


model GstParty {
  id                  String   @id @default(uuid())
  gstin               String?  @unique
  legalName           String
  tradeName           String?
  customerProfileId   String?
  email               String?
  phone               String?
  stateCode           String?
  countryCode         String   @default("IN")
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customer            CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  auditLogs           GstAuditLog[]
  legacyDocuments     GstLegacyDocument[]

  @@index([customerProfileId])
  @@index([legalName])
}

model GstExport {
  id                  String   @id @default(uuid())
  gstSettingsId       String
  exportType          String
  periodStart         DateTime
  periodEnd           DateTime
  status              String
  storageUrl          String?
  checksum            String?
  filters             Json?
  generatedByType     String?
  generatedById       String?
  generatedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  gstSettings         GstSettings @relation(fields: [gstSettingsId], references: [id], onDelete: Cascade)
  items               GstExportItem[]
  auditLogs           GstAuditLog[]

  @@index([gstSettingsId, periodStart, periodEnd])
  @@index([status, createdAt])
  @@unique([gstSettingsId, exportType, periodStart, periodEnd])
}

model GstExportItem {
  id                  String   @id @default(uuid())
  gstExportId         String
  gstDocumentId       String?
  rowNumber           Int
  documentType        GstDocumentType?
  documentNumber      String?
  documentDate        DateTime?
  status              String
  payload             Json
  errorCode           String?
  errorMessage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  gstExport           GstExport    @relation(fields: [gstExportId], references: [id], onDelete: Cascade)
  gstDocument         GstDocument? @relation(fields: [gstDocumentId], references: [id], onDelete: SetNull)

  @@unique([gstExportId, rowNumber])
  @@index([gstDocumentId])
  @@index([status])
  @@index([documentType, documentDate])
}

model GstReconciliationRun {
  id                  String   @id @default(uuid())
  gstSettingsId       String
  periodStart         DateTime
  periodEnd           DateTime
  sourceSystem        String
  status              String
  matchedCount        Int      @default(0)
  mismatchedCount     Int      @default(0)
  missingInBooksCount Int      @default(0)
  missingInPortalCount Int     @default(0)
  summary             Json?
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  gstSettings         GstSettings @relation(fields: [gstSettingsId], references: [id], onDelete: Cascade)
  auditLogs           GstAuditLog[]

  @@index([gstSettingsId, periodStart, periodEnd])
  @@index([status, startedAt])
}

model GstAuditLog {
  id                  String   @id @default(uuid())
  gstSettingsId       String?
  gstDocumentId       String?
  gstPartyId          String?
  gstExportId         String?
  reconciliationRunId String?
  action              String
  actorType           String
  actorId             String?
  previousState       Json?
  nextState           Json?
  metadata            Json?
  createdAt           DateTime @default(now())

  gstSettings         GstSettings? @relation(fields: [gstSettingsId], references: [id], onDelete: SetNull)
  gstDocument         GstDocument? @relation(fields: [gstDocumentId], references: [id], onDelete: SetNull)
  gstParty            GstParty?    @relation(fields: [gstPartyId], references: [id], onDelete: SetNull)
  gstExport           GstExport?   @relation(fields: [gstExportId], references: [id], onDelete: SetNull)
  reconciliationRun   GstReconciliationRun? @relation(fields: [reconciliationRunId], references: [id], onDelete: SetNull)

  @@index([gstDocumentId, createdAt])
  @@index([gstPartyId, createdAt])
  @@index([gstExportId, createdAt])
  @@index([reconciliationRunId, createdAt])
  @@index([action, createdAt])
}

model GstLegacyDocument {
  id                  String   @id @default(uuid())
  sourceSystem        String
  legacyDocumentId    String
  legacyDocumentNumber String?
  documentType        GstDocumentType?
  documentStatus      GstDocumentStatus?
  gstDocumentId       String?
  gstPartyId          String?
  payload             Json?
  importedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  gstDocument         GstDocument? @relation(fields: [gstDocumentId], references: [id], onDelete: SetNull)
  gstParty            GstParty?    @relation(fields: [gstPartyId], references: [id], onDelete: SetNull)

  @@unique([sourceSystem, legacyDocumentId])
  @@index([legacyDocumentNumber])
  @@index([gstDocumentId])
  @@index([gstPartyId])
}
enum GstDocumentType {
  TAX_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
  DELIVERY_CHALLAN
}

enum GstDocumentStatus {
  DRAFT
  FINALIZED
  CANCELLED
  VOID
}

enum GstPartyType {
  SELLER
  CUSTOMER
  CONSIGNEE
  SHIP_FROM
  SHIP_TO
}

enum GstSupplyType {
  B2B
  B2C
  EXPORT
  SEZ
  DEEMED_EXPORT
}

enum GstTaxRateType {
  NIL
  ZERO
  GST_003
  GST_005
  GST_012
  GST_018
  GST_028
}

enum GstReconciliationStatus {
  PENDING
  MATCHED
  MISMATCH
  MISSING_IN_SOURCE
  MISSING_IN_TARGET
  ERROR
}

model GstSettings {
  id                       String   @id @default(cuid())
  legalName                String
  tradeName                String?
  gstin                    String   @unique
  pan                      String?
  email                    String?
  phone                    String?
  addressLine1             String
  addressLine2             String?
  city                     String
  state                    String
  stateCode                String
  postalCode               String
  country                  String   @default("IN")
  invoicePrefix            String   @default("GST")
  creditNotePrefix         String   @default("CN")
  debitNotePrefix          String   @default("DN")
  invoiceSequencePadding   Int      @default(6)
  financialYearStartMonth  Int      @default(4)
  defaultPlaceOfSupply     String?
  defaultCurrency          String   @default("INR")
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  counters                 GstCounter[]
  documents                GstDocument[]

  @@index([isActive])
}

model GstCounter {
  id             String   @id @default(cuid())
  settingsId     String
  settings       GstSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  scope          String
  financialYear  String
  currentValue   Int      @default(0)
  prefix         String
  padding        Int      @default(6)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([settingsId, scope, financialYear])
  @@index([settingsId])
}

model GstParty {
  id                String   @id @default(cuid())
  type              GstPartyType
  name              String
  gstin             String?
  pan               String?
  email             String?
  phone             String?
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  stateCode         String
  postalCode        String
  country           String   @default("IN")
  placeOfSupply     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  soldDocuments     GstDocument[] @relation("SoldToParty")
  billedDocuments   GstDocument[] @relation("BilledByParty")
}

model GstDocument {
  id                    String   @id @default(cuid())
  settingsId            String
  settings              GstSettings @relation(fields: [settingsId], references: [id], onDelete: Restrict)

  documentType          GstDocumentType
  status                GstDocumentStatus @default(DRAFT)
  documentNumber        String?  @unique
  sequenceNumber        Int?
  financialYear         String?

  issueDate             DateTime
  supplyDate            DateTime?
  dueDate               DateTime?

  currency              String   @default("INR")
  supplyType            GstSupplyType?
  placeOfSupply         String?
  reverseCharge         Boolean  @default(false)
  eCommerceGstin        String?

  sourceOrderId         String?
  sourceOrderNumber     String?
  sourceReference       String?

  sellerPartyId         String?
  sellerParty           GstParty? @relation("BilledByParty", fields: [sellerPartyId], references: [id], onDelete: SetNull)

  customerPartyId       String?
  customerParty         GstParty? @relation("SoldToParty", fields: [customerPartyId], references: [id], onDelete: SetNull)

  subtotalAmount        Decimal  @db.Decimal(18, 2)
  discountAmount        Decimal  @default(0) @db.Decimal(18, 2)
  taxableAmount         Decimal  @default(0) @db.Decimal(18, 2)
  cgstAmount            Decimal  @default(0) @db.Decimal(18, 2)
  sgstAmount            Decimal  @default(0) @db.Decimal(18, 2)
  igstAmount            Decimal  @default(0) @db.Decimal(18, 2)
  cessAmount            Decimal  @default(0) @db.Decimal(18, 2)
  roundOffAmount        Decimal  @default(0) @db.Decimal(18, 2)
  totalAmount           Decimal  @db.Decimal(18, 2)

  notes                 String?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  lines                 GstDocumentLine[]
  exports               GstExportItem[]
  auditLogs             GstAuditLog[]

  @@index([settingsId, issueDate])
  @@index([documentType, status])
  @@index([sourceOrderId])
  @@index([sourceOrderNumber])
}

model GstDocumentLine {
  id                    String   @id @default(cuid())
  documentId            String
  document              GstDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  lineNumber            Int
  sku                   String?
  hsnOrSac              String?
  description           String
  quantity              Decimal  @default(1) @db.Decimal(18, 3)
  unit                  String?
  unitPrice             Decimal  @db.Decimal(18, 2)
  grossAmount           Decimal  @db.Decimal(18, 2)
  discountAmount        Decimal  @default(0) @db.Decimal(18, 2)
  taxableAmount         Decimal  @db.Decimal(18, 2)

  taxRateType           GstTaxRateType
  taxRatePercent        Decimal  @default(0) @db.Decimal(5, 2)
  cgstAmount            Decimal  @default(0) @db.Decimal(18, 2)
  sgstAmount            Decimal  @default(0) @db.Decimal(18, 2)
  igstAmount            Decimal  @default(0) @db.Decimal(18, 2)
  cessAmount            Decimal  @default(0) @db.Decimal(18, 2)

  totalAmount           Decimal  @db.Decimal(18, 2)
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([documentId, lineNumber])
  @@index([documentId])
  @@index([sku])
  @@index([hsnOrSac])
}

model GstExport {
  id                    String   @id @default(cuid())
  exportType            String
  periodKey             String
  fileName              String?
  storageKey            String?
  checksum              String?
  status                String   @default("GENERATED")
  generatedAt           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  items                 GstExportItem[]

  @@index([exportType, periodKey])
}

model GstExportItem {
  id                    String   @id @default(cuid())
  exportId              String
  export                GstExport @relation(fields: [exportId], references: [id], onDelete: Cascade)

  documentId            String
  document              GstDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt             DateTime @default(now())

  @@unique([exportId, documentId])
  @@index([documentId])
}

model GstReconciliationRun {
  id                    String   @id @default(cuid())
  runType               String
  periodKey             String
  status                String   @default("COMPLETED")
  summary               Json?
  startedAt             DateTime @default(now())
  completedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([runType, periodKey])
}

model GstAuditLog {
  id                    String   @id @default(cuid())
  documentId            String?
  document              GstDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  action                String
  actorType             String?
  actorId               String?
  payload               Json?
  createdAt             DateTime @default(now())

  @@index([documentId, createdAt])
  @@index([action, createdAt])
}

model GstLegacyDocument {
  id                    String   @id @default(cuid())
  legacySystem          String
  legacyDocumentId      String
  legacyDocumentNumber  String?
  documentType          String?
  rawPayload            Json
  migratedToDocumentId  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([legacySystem, legacyDocumentId])
  @@index([migratedToDocumentId])
}
