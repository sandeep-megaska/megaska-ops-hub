generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model MegaskaCustomerProfile {
  id                String                       @id @default(cuid())
  phoneE164         String                       @unique
  email             String?
  firstName         String?
  lastName          String?
  shopifyCustomerId String?                      @unique
  marketingOptIn    Boolean                      @default(false)
  authSessions      MegaskaCustomerAuthSession[]
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@index([email])
}

model MegaskaCustomerAuthSession {
  id                String                  @id @default(cuid())
  sessionTokenHash  String                  @unique
  phoneE164         String
  customerProfileId String?
  customerProfile   MegaskaCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  expiresAt         DateTime
  revokedAt         DateTime?
  lastSeenAt        DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([phoneE164])
  @@index([customerProfileId])
  @@index([expiresAt])
  @@index([revokedAt])
}
